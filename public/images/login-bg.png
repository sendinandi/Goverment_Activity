<td colspan="14" style="text-align:center;font-size:85%"><i>Sumber <span typeof="mw:Entity">#</span>1: BMKG<sup about="#mwt64" class="mw-ref reference" id="cite_ref-13" rel="dc:references" typeof="mw:Extension/ref" data-mw="{&quot;name&quot;:&quot;ref&quot;,&quot;attrs&quot;:{},&quot;body&quot;:{&quot;id&quot;:&quot;mw-reference-text-cite_note-13&quot;}}"><a href="#cite_note-13" id="mw-w"><span class="mw-reflink-text" id="mw_A"><span class="cite-bracket" id="mw_Q">[</span>11<span class="cite-bracket" id="mw_g">]</span></span></a></sup></i></td></tr>
<tr>
